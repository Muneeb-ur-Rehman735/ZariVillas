ntact-overlay{position:fixed;inset:0;z-index:100001;display:flex;align-items:center;justify-content:center;background:#0006;-webkit-backdrop-filter:blur(4px);backdrop-filter:blur(4px);pointer-events:all;opacity:0;transition:opacity .2s ease}.askify-contact-overlay.visible{opacity:1}.askify-contact-modal{width:380px;max-width:90vw;background:#fff;border-radius:16px;box-shadow:0 25px 60px #0003;overflow:hidden;position:relative;transform:translateY(20px) scale(.95);opacity:0;transition:all .3s cubic-bezier(.16,1,.3,1)}.askify-contact-modal.visible{transform:translateY(0) scale(1);opacity:1}.askify-contact-close{position:absolute;top:12px;right:12px;width:32px;height:32px;border-radius:8px;border:none;background:#fff3;color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background .15s;z-index:2}.askify-contact-close:hover{background:#ffffff59}.askify-contact-header{padding:32px 28px;color:#fff}.askify-contact-title{font-size:18px;font-weight:600;line-height:1.4;margin:0;padding-right:24px}.askify-contact-form{padding:24px 28px 28px;display:flex;flex-direction:column;gap:14px}.askify-contact-field{display:flex;align-items:center;gap:12px;background:#f9fafb;border:1px solid #e5e7eb;border-radius:10px;padding:0 14px;transition:border-color .15s,box-shadow .15s}.askify-contact-field:focus-within{border-color:#d1d5db;outline:none!important}.askify-contact-icon{color:#9ca3af;flex-shrink:0}.askify-contact-input{flex:1;padding:14px 0;border:none;background:transparent;font-size:14px;color:#111;outline:none;font-family:inherit}.askify-contact-input::-moz-placeholder{color:#9ca3af}.askify-contact-input::placeholder{color:#9ca3af}.askify-contact-submit{display:flex;align-items:center;justify-content:center;gap:8px;width:100%;padding:14px;border:none;border-radius:10px;color:#fff;font-size:15px;font-weight:600;cursor:pointer;transition:opacity .15s,transform .1s;font-family:inherit;margin-top:4px}.askify-contact-submit:hover:not(:disabled){o